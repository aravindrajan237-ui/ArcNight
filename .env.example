# ============================================================================
# HarvestLink — environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. Only NEXT_PUBLIC_* vars are exposed to the browser.
# ============================================================================

# ---- App ----
# Public base URL of the app (used for auth redirects + Razorpay callbacks).
# Local dev: http://localhost:3000  |  Prod: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Supabase ----
# Project URL + anon key are safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service-role key is SECRET. Server-side only (route handlers / admin client).
# Bypasses Row Level Security — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- Google Gemini (market price estimate / fair_deal_score) ----
GEMINI_API_KEY=your-gemini-api-key

# ---- Razorpay (TEST mode) ----
# Get test keys from Razorpay Dashboard > Settings > API Keys (Test Mode).
# The key_id is needed client-side to open the checkout widget.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-test-secret


# ---- data.gov.in (OPTIONAL — mandi / market price reference data) ----
# Pricing falls back to local history if this is unset.
DATA_GOV_IN_API_KEY=your-data-gov-in-api-key

# ---- Demo mode (OPTIONAL) ----
# When "true", the login screen offers a one-tap farmer/buyer role picker that
# acts as the seeded demo users below — handy for UI testing without signing up.
# Keep this "false" (or unset) in production.
NEXT_PUBLIC_DEMO_MODE=false
DEMO_FARMER_ID=
DEMO_BUYER_ID=
